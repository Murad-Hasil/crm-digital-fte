# =============================================================================
# DATABASE
# =============================================================================
DATABASE_URL=postgresql://fte_user:fte_password@localhost:5432/fte_db

# =============================================================================
# LLM (OpenAI Agents SDK configured for Groq)
# =============================================================================
GROQ_API_KEY=gsk_your_groq_api_key_here
OPENAI_BASE_URL=https://api.groq.com/openai/v1
MODEL_NAME=llama-3.3-70b-versatile

# =============================================================================
# KAFKA
# =============================================================================
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# =============================================================================
# GMAIL (Google Cloud Pub/Sub + OAuth2)
# =============================================================================
GMAIL_CREDENTIALS_PATH=credentials/gmail_credentials.json
GMAIL_PUBSUB_TOPIC=projects/your-project/topics/gmail-push
GMAIL_ENABLED=true

# =============================================================================
# WHATSAPP / TWILIO
# =============================================================================
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886
WHATSAPP_ENABLED=true

# =============================================================================
# WEB FORM
# =============================================================================
WEBFORM_ENABLED=true
CORS_ORIGINS=http://localhost:3000

# =============================================================================
# APPLICATION
# =============================================================================
ENVIRONMENT=development
LOG_LEVEL=INFO
MAX_EMAIL_LENGTH=2000
MAX_WHATSAPP_LENGTH=1600
MAX_WEBFORM_LENGTH=1000
